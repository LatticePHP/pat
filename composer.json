{
    "name": "lattice/pat",
    "description": "Personal Access Token authentication for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "personal-access-token",
        "authentication",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/pat"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "lattice/auth": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Pat\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Pat\\Tests\\": "tests/"
        }
    }
}
